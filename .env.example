APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:sPADXQpmKLHfByH3cD0yW4qIvxLXSzjF8aU6fdwJyeo=
APP_DEBUG=true

# Portal runs on its own domain. All modules are subdomains of this domain.
# HTTPS is required — SameSite=None cookies will not be sent over HTTP.
APP_URL=https://deoris.test

# Module URLs — each module is a subdomain of deoris.test.
# mkcert deoris.test "*.deoris.test" covers all of these.
ENTRYEASE_URL=https://entryease.deoris.test
ENROLLEASE_URL=https://enrollease.deoris.test
GRADETRACK_URL=https://gradetrack.deoris.test
MEDITRACK_URL=https://meditrack.deoris.test
LIBRARYSYS_URL=https://librarysys.deoris.test
TASKFLOW_URL=https://taskflow.deoris.test
CAREERCONNECT_URL=https://careerconnect.deoris.test
ASSESSPAY_URL=https://assesspay.deoris.test
VOTESYS_URL=https://votesys.deoris.test
CLEARCHECK_URL=https://clearcheck.deoris.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=deoris_identity_db
DB_USERNAME=root
DB_PASSWORD=

# Session — SameSite=None + Secure is required for cookies to be sent inside
# cross-origin iframes (modules embedded in the portal shell).
# SESSION_DOMAIN with a leading dot covers deoris.test and all subdomains.
SESSION_DRIVER=database
SESSION_COOKIE=deoris_identity_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none
SESSION_PATH=/
SESSION_DOMAIN=".deoris.test"

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PUBSUB_DB=2
REDIS_QUEUE=events
REDIS_QUEUE_RETRY_AFTER=120
REDIS_QUEUE_BLOCK_FOR=5

DEORIS_EVENTS_REDIS_CHANNEL=deoris.events
DEORIS_EVENT_QUEUE=events
DEORIS_NOTIFICATION_QUEUE=notifications
DEORIS_SEARCH_CACHE_SECONDS=60
DEORIS_EVENT_REPLAY_WINDOW_SECONDS=300

ENTRYEASE_EVENT_SECRET=5cd86a067990d98ff2e4f1a68f895bd5477dd40b9d5fe033fba4657395e32a8b
ENROLLEASE_EVENT_SECRET=c50c2208cf70c9d8e6bf560301d35966d7dc7d0ced06e2cc6d329a67ae62488f
