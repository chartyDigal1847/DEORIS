APP_NAME="DEORIS Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Local XAMPP domain. Production values are documented at the bottom.
APP_URL=https://deoris.test

# Local module URLs.
ENTRYEASE_URL=https://entryease.deoris.test
ENROLLEASE_URL=https://enrollease.deoris.test
GRADETRACK_URL=https://gradetrack.deoris.test
MEDITRACK_URL=https://meditrack.deoris.test
LIBRARYSYS_URL=https://librarysys.deoris.test
TASKFLOW_URL=https://taskflow.deoris.test
CAREERCONNECT_URL=https://careerconnect.deoris.test
ASSESSPAY_URL=https://assesspay.deoris.test
VOTESYS_URL=https://votesys.deoris.test
CLEARCHECK_URL=https://clearcheck.deoris.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=deoris_identity_db
DB_USERNAME=root
DB_PASSWORD=

# Session — SameSite=None + Secure is required for cookies to be sent inside
# cross-origin iframes (modules embedded in the portal shell).
# SESSION_DOMAIN with a leading dot covers deoris.test and all subdomains.
SESSION_DRIVER=database
SESSION_COOKIE=deoris_identity_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none
SESSION_PATH=/
SESSION_DOMAIN=.deoris.test

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PUBSUB_DB=2
REDIS_QUEUE=events
REDIS_QUEUE_RETRY_AFTER=120
REDIS_QUEUE_BLOCK_FOR=5

DEORIS_EVENTS_REDIS_CHANNEL=deoris.events
DEORIS_EVENT_QUEUE=events
DEORIS_NOTIFICATION_QUEUE=notifications
DEORIS_SEARCH_CACHE_SECONDS=60
DEORIS_EVENT_REPLAY_WINDOW_SECONDS=300

ENTRYEASE_EVENT_SECRET=change-me-entryease
ENROLLEASE_EVENT_SECRET=change-me-enrollease
GRADETRACK_EVENT_SECRET=change-me-gradetrack
MEDITRACK_EVENT_SECRET=change-me-meditrack
LIBRARYSYS_EVENT_SECRET=change-me-librarysys
TASKFLOW_EVENT_SECRET=change-me-taskflow
CAREERCONNECT_EVENT_SECRET=change-me-careerconnect
ASSESSPAY_EVENT_SECRET=change-me-assesspay
VOTESYS_EVENT_SECRET=change-me-votesys
CLEARCHECK_EVENT_SECRET=change-me-clearcheck

ENTRYEASE_SEARCH_TOKEN=change-me-entryease-search-token
ENROLLEASE_SEARCH_TOKEN=change-me-enrollease-search-token
GRADETRACK_SEARCH_TOKEN=change-me-gradetrack-search-token
MEDITRACK_SEARCH_TOKEN=change-me-meditrack-search-token
LIBRARYSYS_SEARCH_TOKEN=change-me-librarysys-search-token
TASKFLOW_SEARCH_TOKEN=change-me-taskflow-search-token
CAREERCONNECT_SEARCH_TOKEN=change-me-careerconnect-search-token
ASSESSPAY_SEARCH_TOKEN=change-me-assesspay-search-token
VOTESYS_SEARCH_TOKEN=change-me-votesys-search-token
CLEARCHECK_SEARCH_TOKEN=change-me-clearcheck-search-token

REVERB_APP_ID=deoris-portal
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=deoris.test
REVERB_PORT=8081
REVERB_SCHEME=https
# Internal: Laravel server → Reverb (plain HTTP on localhost, no SSL)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081
REVERB_SERVER_SCHEME=http
# Broadcaster internal connect address (127.0.0.1, not 0.0.0.0)
REVERB_BROADCASTER_HOST=127.0.0.1
REVERB_ALLOWED_ORIGINS=https://deoris.test

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@deoris.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum stateful domains — all origins that send session cookies to the portal API.
SANCTUM_STATEFUL_DOMAINS=deoris.test,entryease.deoris.test,enrollease.deoris.test,gradetrack.deoris.test,meditrack.deoris.test,librarysys.deoris.test,taskflow.deoris.test,careerconnect.deoris.test,assesspay.deoris.test,votesys.deoris.test,clearcheck.deoris.test

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

